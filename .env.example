# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_CRIADOR=gpt-5.4-2026-03-05
OPENAI_MODEL_CLIENTE=gpt-5.4-2026-03-05
OPENAI_MODEL_MODERADOR=gpt-5.4-mini-2026-03-17
OPENAI_MODEL_INTENCAO=gpt-5.4-mini-2026-03-17
OPENAI_MODEL_GERENTE=gpt-5.4-2026-03-05

# App session — APP_SESSION_SECRET MUST be a long random string in production
APP_SESSION_SECRET=
APP_SESSION_TTL_HOURS=24

# Auth
AUTH_CODE_TTL_MINUTES=15
AUTH_MAX_VERIFY_ATTEMPTS=5
AUTH_REQUEST_RATE_LIMIT_PER_MINUTE=5
SHOW_DEVELOPMENT_CODE_PREVIEW=false

# Admin dashboard — comma-separated list of e-mails with /admin access
ADMIN_EMAILS=

# Magic-link e-mail (Resend) — required to actually deliver the access link.
# Without RESEND_API_KEY the dev code pill still works as a fallback.
RESEND_API_KEY=
EMAIL_FROM="RNaves Simulador <onboarding@resend.dev>"

# Misc
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
